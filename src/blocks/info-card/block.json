{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "rrze-elements/info-card",
  "version": "1.1.7",
  "title": "Info card",
  "category": "rrze_elements",
  "ancestor": ["rrze-elements/carousel"],
  "description": "Creates an info card for use in Carousels or on its own.",
  "supports": {
    "html": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "default": ""
    },
    "subtitle": {
      "type": "string",
      "default": ""
    },
    "desktopImageId": {
      "type": "number",
      "default": 0
    },
    "desktopImageUrl": {
      "type": "string",
      "default": ""
    },
    "tabletImageId": {
      "type": "number",
      "default": 0
    },
    "tabletImageUrl": {
      "type": "string",
      "default": ""
    },
    "mobileImageId": {
      "type": "number",
      "default": 0
    },
    "mobileImageUrl": {
      "type": "string",
      "default": ""
    }
  },
  "textdomain": "rrze-elements-blocks",
  "editorScript": "file:./index.ts",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css"
}
