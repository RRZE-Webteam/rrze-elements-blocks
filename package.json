{
	"name": "rrze-elements-blocks",
	"version": "1.1.7",
	"description": "RRZE Elements: Gestalterische Erweiterungen für den BlockEditor",
	"main": "build/index.js",
	"textdomain": "rrze-elements-blocks",
	"license": "GPL-3.0-or-later",
	"private": true,
	"scripts": {
		"build": "wp-scripts build && sass --style=compressed --no-source-map src/_shared/scss/rrze-elements-blocks.scss assets/css/rrze-elements-blocks.css && sass --style=compressed --no-source-map src/_shared/scss/rrze-elements-blocks-elemental-compatibility.scss assets/css/rrze-elements-blocks-elemental-compatibility.css",
		"format": "wp-scripts format",
		"lint:css": "wp-scripts lint-style",
		"lint": "eslint 'src/**/*.{js,jsx,ts,tsx}'",
		"test": "composer phpstan",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip",
		"start": "concurrently \"wp-scripts start\" \"sass src/_shared/scss/rrze-elements-blocks.scss assets/css/rrze-elements-blocks.css -w\" \"sass src/_shared/scss/rrze-elements-blocks-elemental-compatibility.scss assets/css/rrze-elements-blocks-elemental-compatibility.css -w\"",
		"build-all": "node check-compatibility.js && sass --style=compressed --no-source-map src/_shared/scss/rrze-elements-blocks.scss assets/css/rrze-elements-blocks.css && npm run build && npx playwright test",
		"update-version": "node update-version.js && npm run build",
		"test:e2e": "NODE_OPTIONS=--use-system-ca playwright test",
    "minify:js": "npx google-closure-compiler --js=assets/js/carousel/rrze-carousel.js --js_output_file=assets/js/carousel/rrze-carousel-min.js --compilation_level=SIMPLE --language_out=ECMASCRIPT_2015\n"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/RRZE-Webteam/rrze-elements",
		"issues": "https://github.com/RRZE-Webteam/rrze-elements/issues",
		"clone": "git+https://github.com/RRZE-Webteam/rrze-elements.git"
	},
	"browserslist": [
		"last 3 years",
		"> 1%",
		"not ie <= 11"
	],
	"supports": {
		"email": "webmaster@fau.de",
		"docs": "https://www.wordpress.rrze.fau.de/plugins/fau-und-rrze-plugins/elements/"
	},
	"author": {
		"name": "RRZE-Webteam <webmaster@fau.de>",
		"url": "https://www.wordpress.rrze.fau.de/person/webmaster"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@babel/preset-env": "^7.29.2",
		"@babel/preset-react": "^7.28.5",
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^9.39.4",
		"@playwright/test": "^1.59.1",
		"@svgr/webpack": "^8.1.0",
		"@types/color": "^4.2.1",
		"@types/lodash": "^4.17.24",
		"@types/node": "^25.5.2",
		"@types/react": "^19.2.14",
		"@types/wordpress__block-editor": "^15.0.5",
		"@types/wordpress__blocks": "^15.10.2",
		"@typescript-eslint/eslint-plugin": "^8.57.2",
		"@typescript-eslint/parser": "^8.57.2",
		"@wordpress/api-fetch": "^7.43.0",
		"@wordpress/babel-plugin-makepot": "^6.42.0",
		"@wordpress/compose": "^7.43.0",
		"@wordpress/data": "^10.43.0",
		"@wordpress/eslint-plugin": "^24.4.0",
		"@wordpress/i18n": "^6.16.0",
		"@wordpress/icons": "^12.1.0",
		"@wordpress/keycodes": "^4.43.0",
		"@wordpress/notices": "^5.43.0",
		"@wordpress/scripts": "^31.8.0",
		"@wordpress/server-side-render": "^6.19.0",
		"autoprefixer": "^10.4.27",
		"babel-loader": "^10.1.1",
		"baseline-browser-mapping": "^2.10.12",
		"concurrently": "^9.2.1",
		"dotenv": "^17.4.1",
		"eslint": "^9.7.0",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-tsdoc": "^0.5.2",
		"inquirer": "^13.4.1",
		"prompt": "^1.3.0",
		"semver": "^7.7.4",
		"ts-loader": "^9.5.7",
		"typescript": "^5.9.3",
    "google-closure-compiler": "^20260406.0.0"
	},
	"dependencies": {
		"@wordpress/a11y": "^4.43.0",
		"@wordpress/shortcode": "^4.43.0",
		"color": "5.0.3",
		"gsap": "^3.14.2",
		"he": "^1.2.0",
		"lodash": "^4.18.1",
		"material-symbols": "^0.44.0",
		"react-error-boundary": "^6.1.1"
  }
}
