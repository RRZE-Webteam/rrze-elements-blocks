{
	"name": "rrze-elements-blocks",
	"version": "1.1.5",
	"description": "RRZE Elements: Gestalterische Erweiterungen für den BlockEditor",
	"main": "build/index.js",
	"textdomain": "rrze-elements-blocks",
	"license": "GPL-3.0-or-later",
	"private": true,
	"scripts": {
		"build": "wp-scripts build --no-stats && sass --style=compressed --no-source-map src/_shared/scss/rrze-elements-blocks.scss assets/css/rrze-elements-blocks.css && sass --style=compressed --no-source-map src/_shared/scss/rrze-elements-blocks-elemental-compatibility.scss assets/css/rrze-elements-blocks-elemental-compatibility.css",
		"format": "wp-scripts format",
		"lint:css": "wp-scripts lint-style",
		"lint": "eslint 'src/**/*.{js,jsx,ts,tsx}'",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip",
		"start": "wp-scripts start & sass src/_shared/scss/rrze-elements-blocks.scss assets/css/rrze-elements-blocks.css -w && sass src/_shared/scss/rrze-elements-blocks-elemental-compatibility.scss assets/css/rrze-elements-blocks-elemental-compatibility.css -w",
		"build-all": "node check-compatibility.js && sass --style=compressed --no-source-map src/_shared/scss/rrze-elements-blocks.scss assets/css/rrze-elements-blocks.css && npm run build && npx playwright test",
		"update-version": "node update-version.js && npm run build",
		"test:e2e": "NODE_OPTIONS=--use-system-ca playwright test"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/RRZE-Webteam/rrze-elements",
		"issues": "https://github.com/RRZE-Webteam/rrze-elements/issues",
		"clone": "git+https://github.com/RRZE-Webteam/rrze-elements.git"
	},
	"browserslist": [
		"last 3 years",
		"> 1%",
		"not ie <= 11"
	],
	"supports": {
		"email": "webmaster@fau.de",
		"docs": "https://www.wordpress.rrze.fau.de/plugins/fau-und-rrze-plugins/elements/"
	},
	"author": {
		"name": "RRZE-Webteam <webmaster@fau.de>",
		"url": "https://www.wordpress.rrze.fau.de/person/webmaster"
	},
	"devDependencies": {
		"@babel/core": "^7.28.5",
		"@babel/preset-env": "^7.28.5",
		"@babel/preset-react": "^7.28.5",
		"@eslint/eslintrc": "^3.3.3",
		"@eslint/js": "^9.39.2",
		"@playwright/test": "^1.57.0",
		"@svgr/webpack": "^8.1.0",
		"@types/color": "^4.2.0",
		"@types/lodash": "^4.17.21",
		"@types/node": "^25.0.3",
		"@types/wordpress__block-editor": "^15.0.0",
		"@types/wordpress__blocks": "^12.5.18",
		"@typescript-eslint/eslint-plugin": "^8.52.0",
		"@typescript-eslint/parser": "^8.52.0",
		"@wordpress/api-fetch": "^7.37.0",
		"@wordpress/babel-plugin-makepot": "^6.37.0",
		"@wordpress/compose": "^7.37.0",
		"@wordpress/data": "^10.37.0",
		"@wordpress/e2e-test-utils-playwright": "^1.37.0",
		"@wordpress/eslint-plugin": "^23.0.0",
		"@wordpress/i18n": "^6.10.0",
		"@wordpress/icons": "^11.4.0",
		"@wordpress/keycodes": "^4.37.0",
		"@wordpress/notices": "^5.37.0",
		"@wordpress/scripts": "^31.2.0",
		"@wordpress/server-side-render": "^6.13.0",
		"autoprefixer": "^10.4.23",
		"babel-loader": "^10.0.0",
		"baseline-browser-mapping": "^2.9.12",
		"dotenv": "^17.2.3",
		"eslint": "^9.39.2",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-tsdoc": "^0.5.0",
		"inquirer": "^13.1.0",
		"prompt": "^1.3.0",
		"semver": "^7.7.3",
		"ts-loader": "^9.5.4",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@wordpress/a11y": "^4.37.0",
		"@wordpress/shortcode": "^4.37.0",
		"color": "^5.0.3",
		"gsap": "^3.14.2",
		"he": "^1.2.0",
		"lodash": "^4.17.21",
		"material-symbols": "^0.40.2",
		"react-error-boundary": "^6.0.2"
	},
	"engines": {
		"node": ">=21.7.3",
		"npm": ">=10.8.0"
	}
}
