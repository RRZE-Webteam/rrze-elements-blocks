{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "rrze-elements/carousel",
  "version": "1.1.7",
  "title": "Carousel",
  "category": "rrze_elements",
  "description": "Creates a Carousel of Info-Cards with Popover, Link or Image Functionality.",
  "supports": {
    "html": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "default": ""
    },
    "cardHeight": {
      "type": "number",
      "default": 350
    },
    "isNestedWarning": {
      "type": "boolean",
      "default": false
    },
    "headingLevel": {
      "type": "number",
      "enum": [
        2,
        3,
        4,
        5,
        6
      ],
      "default": 2
    }
  },
  "styles": [
    {
      "name": "scientific",
      "label": "Scientific",
      "isDefault": true
    },
    {
      "name": "marketing",
      "label": "Marketing"
    }
  ],
  "textdomain": "rrze-elements-blocks",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css"
}