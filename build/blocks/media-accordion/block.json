{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "rrze-elements/media-accordion",
  "version": "1.2.0",
  "title": "Media & Accordions",
  "category": "rrze_elements",
  "description": "Add Images next to your Accordions.",
  "supports": {
    "html": false
  },
  "attributes": {
    "viewRatio": {
      "type": "string",
      "default": "2:1",
      "enum": [
        "2:1",
        "1:2"
      ]
    }
  },
  "textdomain": "rrze-elements-blocks",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScript": "rrze-media-accordion"
}